# ===========================================================================
# RFQ Automation Platform — environment configuration
# Copy to `.env.local` (dev) or provide as container env (prod).
# ===========================================================================

# Public app URL (used for OAuth redirect + absolute links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Supabase (you said this is already set up — paste your project values)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — server-only, NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Storage bucket for RFQ PDFs (created by the migration)
SUPABASE_STORAGE_BUCKET=rfq-pdfs

# If the three Supabase vars above are omitted, the app runs against an
# in-memory store seeded with sample data (great for a first look).

# ---------------------------------------------------------------------------
# Microsoft Graph / Outlook OAuth
# Register an app at https://entra.microsoft.com (Azure AD) and paste here.
# Redirect URI must be: {NEXT_PUBLIC_APP_URL}/api/auth/outlook/callback
# Required delegated permissions: Mail.Send, User.Read, offline_access
# ---------------------------------------------------------------------------
MS_TENANT_ID=common
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# Optional explicit override (defaults to {APP_URL}/api/auth/outlook/callback)
# MS_REDIRECT_URI=http://localhost:3000/api/auth/outlook/callback

# ---------------------------------------------------------------------------
# Mock / dev switches — exercise the whole workflow with no external accounts.
# ---------------------------------------------------------------------------
# Return deterministic fake suppliers instead of launching Playwright.
MOCK_SEARCH=false
# Simulate Outlook sending (defaults to true automatically when MS_* unset).
MOCK_EMAIL=true

# ---------------------------------------------------------------------------
# Search tuning
# ---------------------------------------------------------------------------
# Max DuckDuckGo results to open & inspect per part number.
SEARCH_MAX_RESULTS=8
