# ===========================================================================
# RFQ Automation Platform — environment configuration
# Copy to `.env.local` (dev) or provide as container env (prod).
# ===========================================================================

# Public app URL (used for OAuth redirect + absolute links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Supabase (you said this is already set up — paste your project values)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — server-only, NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Storage bucket for RFQ PDFs (created by the migration)
SUPABASE_STORAGE_BUCKET=rfq-pdfs

# If the three Supabase vars above are omitted, the app runs against an
# in-memory store seeded with sample data (great for a first look).

# ---------------------------------------------------------------------------
# Outlook email via SMTP (no Azure required).
# Use a personal Outlook.com account with an app password:
#   1. Enable 2-step verification: https://account.microsoft.com/security
#   2. Create an app password:      https://account.live.com/proofs/AppPassword
# ---------------------------------------------------------------------------
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_USER=your-address@outlook.com
SMTP_PASS=your-app-password
# Optional — defaults to SMTP_USER.
# SMTP_FROM=your-address@outlook.com

# ---------------------------------------------------------------------------
# Mock / dev switches — exercise the whole workflow with no external accounts.
# ---------------------------------------------------------------------------
# Return deterministic fake suppliers instead of launching Playwright.
MOCK_SEARCH=false
# Simulate Outlook sending (defaults to true automatically when SMTP_* unset).
MOCK_EMAIL=true

# ---------------------------------------------------------------------------
# Search tuning
# ---------------------------------------------------------------------------
# Max DuckDuckGo results to open & inspect per part number.
SEARCH_MAX_RESULTS=8
